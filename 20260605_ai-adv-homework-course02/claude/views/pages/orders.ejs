<div id="app" style="padding:56px 96px;display:flex;flex-direction:column;gap:32px;">

  <!-- Header -->
  <div style="display:flex;justify-content:space-between;align-items:flex-end;">
    <h1 style="font-family:'Newsreader',serif;font-size:44px;font-style:italic;font-weight:400;color:#F0EAD8;">我的訂單</h1>
    <span v-if="orders.length" style="font-family:'Geist',sans-serif;font-size:13px;color:#7A9088;">共 {{ orders.length }} 筆訂單</span>
  </div>

  <!-- Status Tabs -->
  <div style="display:flex;gap:8px;">
    <button
      v-for="tab in tabs"
      :key="tab.value"
      @click="activeStatus = tab.value"
      style="font-family:'Geist',sans-serif;font-size:13px;padding:8px 20px;border-radius:9999px;cursor:pointer;border:1px solid;transition:all 0.15s;"
      :style="activeStatus === tab.value
        ? 'background:#C9A96E;border-color:#C9A96E;color:#0E1A14;'
        : 'background:#1A2D24;border-color:#2A3D33;color:#7A9088;'"
    >{{ tab.label }}</button>
  </div>

  <div v-if="loading" style="display:flex;justify-content:center;padding:4rem 0;">
    <div class="spinner"></div>
  </div>

  <div v-else-if="filteredOrders.length === 0" style="text-align:center;padding:5rem 0;">
    <p style="font-family:'Newsreader',serif;font-size:3rem;color:#2A3D33;margin-bottom:1rem;">✦</p>
    <p style="font-family:'Newsreader',serif;font-size:1.5rem;font-style:italic;color:#F0EAD8;margin-bottom:0.5rem;">尚無訂單</p>
    <p style="font-family:'Geist',sans-serif;font-size:0.875rem;color:#7A9088;margin-bottom:2rem;">快去選購喜歡的花束吧！</p>
    <a href="/" class="btn-gold">去逛逛</a>
  </div>

  <div v-else style="display:flex;flex-direction:column;gap:12px;">
    <a
      v-for="order in filteredOrders"
      :key="order.id"
      :href="'/orders/' + order.id"
      style="display:flex;align-items:center;gap:20px;padding:20px 24px;background:#1A2D24;border:1px solid #2A3D33;border-radius:10px;text-decoration:none;transition:border-color 0.15s,transform 0.15s;"
      onmouseover="this.style.borderColor='#C9A96E66';this.style.transform='translateY(-1px)'"
      onmouseout="this.style.borderColor='#2A3D33';this.style.transform=''"
    >
      <div style="flex:1;display:flex;flex-direction:column;gap:5px;">
        <p style="font-family:'Geist',sans-serif;font-size:13px;font-weight:500;color:#F0EAD8;">{{ order.order_no }}</p>
        <p style="font-family:'Geist',sans-serif;font-size:11px;color:#7A9088;">{{ new Date(order.created_at).toLocaleDateString('zh-TW') }}</p>
      </div>

      <span style="font-family:'Newsreader',serif;font-size:22px;color:#F0EAD8;">NT$ {{ order.total_amount.toLocaleString() }}</span>

      <span
        style="font-family:'Geist',sans-serif;font-size:12px;font-weight:500;padding:6px 14px;border-radius:9999px;"
        :class="{
          'badge-paid': order.status === 'paid',
          'badge-pending': order.status === 'pending',
          'badge-failed': order.status === 'failed'
        }"
      >{{ statusMap[order.status]?.label || order.status }}</span>

      <span style="font-family:'Geist',sans-serif;font-size:13px;color:#7A9088;padding:8px 16px;border:1px solid #2A3D33;border-radius:8px;">查看 →</span>
    </a>
  </div>
</div>
