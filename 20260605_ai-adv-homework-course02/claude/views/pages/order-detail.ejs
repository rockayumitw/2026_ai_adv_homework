<div id="app" data-order-id="<%= orderId %>" data-payment-result="<%= paymentResult %>" style="padding:3rem 6rem;">

  <div v-if="loading" style="display:flex;justify-content:center;padding:5rem 0;">
    <div class="spinner"></div>
  </div>

  <template v-else-if="order">
    <!-- Payment Result Alert -->
    <div v-if="paymentResult && paymentMessages[paymentResult]"
      style="border-radius:0.5rem;padding:1rem 1.25rem;margin-bottom:1.5rem;font-size:0.875rem;"
      :style="{ background: paymentResult === 'success' ? '#6B9E6B22' : '#C0504D22', color: paymentResult === 'success' ? '#6B9E6B' : '#C0504D', border: '1px solid ' + (paymentResult === 'success' ? '#6B9E6B44' : '#C0504D44') }"
    >
      {{ paymentMessages[paymentResult].text }}
    </div>

    <div style="display:flex;gap:2.5rem;align-items:flex-start;">

      <!-- Left -->
      <div style="flex:1;display:flex;flex-direction:column;gap:1.5rem;">

        <!-- Header -->
        <div style="display:flex;justify-content:space-between;align-items:flex-start;">
          <div>
            <h1 class="font-display" style="font-family:'Newsreader',serif;font-size:2.5rem;font-style:italic;color:#F0EAD8;margin-bottom:0.4rem;">訂單詳情</h1>
            <p style="font-size:0.75rem;letter-spacing:0.05em;color:#7A9088;">{{ order.order_no }}</p>
          </div>
          <span
            style="font-size:0.8rem;font-weight:500;padding:0.4rem 1.1rem;border-radius:9999px;"
            :class="{
              'badge-paid': order.status === 'paid',
              'badge-pending': order.status === 'pending',
              'badge-failed': order.status === 'failed'
            }"
          >✦ {{ statusMap[order.status]?.label || order.status }}</span>
        </div>

        <!-- Items Table -->
        <div class="card" style="overflow:hidden;">
          <table style="width:100%;border-collapse:collapse;font-size:0.875rem;">
            <thead style="background:#162318;">
              <tr>
                <th style="text-align:left;padding:0.9rem 1.25rem;font-size:0.7rem;font-weight:500;letter-spacing:0.12em;color:#3A6050;">商品</th>
                <th style="text-align:right;padding:0.9rem 1rem;font-size:0.7rem;font-weight:500;letter-spacing:0.12em;color:#3A6050;">單價</th>
                <th style="text-align:right;padding:0.9rem 1rem;font-size:0.7rem;font-weight:500;letter-spacing:0.12em;color:#3A6050;">數量</th>
                <th style="text-align:right;padding:0.9rem 1.25rem;font-size:0.7rem;font-weight:500;letter-spacing:0.12em;color:#3A6050;">小計</th>
              </tr>
            </thead>
            <tbody>
              <tr v-for="(item, i) in order.items" :key="item.id"
                :style="{ background: i % 2 === 0 ? '#1A2D24' : '#162318', borderBottom: '1px solid #2A3D33' }">
                <td style="padding:1rem 1.25rem;color:#F0EAD8;font-family:'Newsreader',serif;font-size:1rem;">{{ item.product_name }}</td>
                <td style="padding:1rem;text-align:right;color:#7A9088;">NT$ {{ item.product_price.toLocaleString() }}</td>
                <td style="padding:1rem;text-align:right;color:#F0EAD8;">{{ item.quantity }}</td>
                <td style="padding:1rem 1.25rem;text-align:right;color:#C9A96E;font-weight:500;">NT$ {{ (item.product_price * item.quantity).toLocaleString() }}</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Recipient -->
        <div class="card" style="padding:1.5rem;">
          <h2 class="font-display" style="font-family:'Newsreader',serif;font-size:1.25rem;color:#F0EAD8;margin-bottom:1rem;">收件資訊</h2>
          <div style="display:flex;flex-direction:column;gap:0.6rem;">
            <div style="display:flex;gap:1rem;font-size:0.85rem;">
              <span style="color:#7A9088;width:4.5rem;flex-shrink:0;">收件人</span>
              <span style="color:#F0EAD8;">{{ order.recipient_name }}</span>
            </div>
            <div style="display:flex;gap:1rem;font-size:0.85rem;">
              <span style="color:#7A9088;width:4.5rem;flex-shrink:0;">電子信箱</span>
              <span style="color:#F0EAD8;">{{ order.recipient_email }}</span>
            </div>
            <div style="display:flex;gap:1rem;font-size:0.85rem;">
              <span style="color:#7A9088;width:4.5rem;flex-shrink:0;">收件地址</span>
              <span style="color:#F0EAD8;">{{ order.recipient_address }}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Summary + Pay -->
      <div style="width:360px;flex-shrink:0;display:flex;flex-direction:column;gap:14px;position:sticky;top:5.5rem;">
        <div class="card" style="padding:1.5rem;">
          <h2 class="font-display" style="font-family:'Newsreader',serif;font-size:1.25rem;color:#F0EAD8;margin-bottom:1rem;">付款摘要</h2>
          <div style="display:flex;flex-direction:column;gap:0.65rem;margin-bottom:0.75rem;">
            <div style="display:flex;justify-content:space-between;font-size:0.85rem;">
              <span style="color:#7A9088;">商品小計</span>
              <span style="color:#F0EAD8;">NT$ {{ (order.total_amount - 120).toLocaleString() }}</span>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:0.85rem;">
              <span style="color:#7A9088;">運費</span>
              <span style="color:#F0EAD8;">NT$ 120</span>
            </div>
          </div>
          <div style="height:1px;background:#2A3D33;margin-bottom:0.75rem;"></div>
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:0.875rem;font-weight:500;color:#F0EAD8;">合計</span>
            <span class="font-display" style="font-family:'Newsreader',serif;font-size:1.5rem;color:#C9A96E;">NT$ {{ order.total_amount.toLocaleString() }}</span>
          </div>
        </div>

        <div v-if="order.status === 'pending'">
          <div v-if="verifying" style="display:flex;align-items:center;gap:0.75rem;font-size:0.85rem;color:#7A9088;margin-bottom:0.75rem;">
            <div class="spinner" style="width:1rem;height:1rem;"></div>
            正在確認付款結果，請稍候...
          </div>
          <button v-else @click="handleEcpayPayment" :disabled="paying" class="btn-gold" style="width:100%;">
            {{ paying ? '處理中...' : '前往綠界付款' }}
          </button>
        </div>

        <a href="/orders" class="btn-ghost" style="width:100%;text-align:center;text-decoration:none;">← 返回訂單列表</a>
      </div>
    </div>
  </template>
</div>
