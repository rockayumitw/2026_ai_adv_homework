<div id="app" style="display:flex;min-height:calc(100vh - 72px);">

  <!-- Left Panel: Quote + Photo -->
  <div style="width:720px;flex-shrink:0;position:relative;overflow:hidden;">
    <img src="https://images.unsplash.com/photo-1780538778877-0e42a940f525?w=800" alt="botanical"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"/>
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(14,26,20,0.7) 0%, rgba(14,26,20,0.85) 100%);"></div>
    <div style="position:relative;padding:5rem 5rem 3rem;">
      <div class="font-display" style="font-family:'Newsreader',serif;font-size:1.1rem;letter-spacing:0.3em;color:#F0EAD8;margin-bottom:3rem;">BLOOM</div>
      <h2 class="font-display" style="font-family:'Newsreader',serif;font-size:3.25rem;font-style:italic;font-weight:400;line-height:1.2;color:#F0EAD8;margin-bottom:1.5rem;">
        "花朵是<br>靈魂的語言"
      </h2>
      <p style="font-size:0.9rem;color:#7A9088;line-height:1.7;">
        加入 BLOOM，探索大自然最純粹的美麗。
      </p>
    </div>
    <div style="position:absolute;bottom:3rem;left:5rem;display:flex;gap:3rem;">
      <div>
        <div class="font-display" style="font-family:'Newsreader',serif;font-size:1.4rem;color:#C9A96E;">5,000+</div>
        <div style="font-size:0.65rem;letter-spacing:0.15em;color:#7A9088;">會員</div>
      </div>
      <div>
        <div class="font-display" style="font-family:'Newsreader',serif;font-size:1.4rem;color:#C9A96E;">200+</div>
        <div style="font-size:0.65rem;letter-spacing:0.15em;color:#7A9088;">花卉品種</div>
      </div>
      <div>
        <div class="font-display" style="font-family:'Newsreader',serif;font-size:1.4rem;color:#C9A96E;">全台</div>
        <div style="font-size:0.65rem;letter-spacing:0.15em;color:#7A9088;">配送</div>
      </div>
    </div>
  </div>

  <!-- Right Panel: Card -->
  <div style="flex:1;display:flex;align-items:center;justify-content:center;background:#0E1A14;padding:2rem;">
    <div class="card" style="width:100%;max-width:420px;padding:48px;border-radius:16px;box-shadow:0 24px 48px rgba(0,0,0,0.7);">
      <h1 class="font-display" style="font-family:'Newsreader',serif;font-size:2.1rem;font-style:italic;color:#F0EAD8;margin-bottom:0.5rem;">歡迎回來</h1>
      <p style="font-size:0.85rem;color:#7A9088;margin-bottom:2rem;">登入您的 BLOOM 帳號</p>

      <!-- Login Form -->
      <form v-if="activeTab === 'login'" @submit.prevent="handleLogin" style="display:flex;flex-direction:column;gap:1.1rem;">
        <div>
          <label style="display:block;font-size:0.7rem;letter-spacing:0.1em;color:#7A9088;margin-bottom:0.4rem;">電子信箱</label>
          <input v-model="loginForm.email" type="email" placeholder="example@email.com" class="input-dark" :class="{ error: errors.email }" />
          <p v-if="errors.email" style="color:#C0504D;font-size:0.75rem;margin-top:0.25rem;">{{ errors.email }}</p>
        </div>
        <div>
          <label style="display:block;font-size:0.7rem;letter-spacing:0.1em;color:#7A9088;margin-bottom:0.4rem;">密碼</label>
          <input v-model="loginForm.password" type="password" placeholder="請輸入密碼" class="input-dark" :class="{ error: errors.password }" />
          <p v-if="errors.password" style="color:#C0504D;font-size:0.75rem;margin-top:0.25rem;">{{ errors.password }}</p>
        </div>
        <div style="text-align:right;">
          <a href="#" style="font-size:0.8rem;color:#C9A96E;">忘記密碼？</a>
        </div>
        <button type="submit" :disabled="submitting" class="btn-gold" style="width:100%;margin-top:0.25rem;">
          {{ submitting ? '登入中...' : '登入' }}
        </button>
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <div style="flex:1;height:1px;background:#2A3D33;"></div>
          <span style="font-size:0.75rem;color:#7A9088;">或</span>
          <div style="flex:1;height:1px;background:#2A3D33;"></div>
        </div>
        <p style="text-align:center;font-size:0.8rem;color:#7A9088;">
          還沒帳號？
          <a href="#" @click.prevent="activeTab='register';errors={}" style="color:#C9A96E;">立即免費加入 →</a>
        </p>
      </form>

      <!-- Register Form -->
      <form v-else @submit.prevent="handleRegister" style="display:flex;flex-direction:column;gap:1.1rem;">
        <div>
          <label style="display:block;font-size:0.7rem;letter-spacing:0.1em;color:#7A9088;margin-bottom:0.4rem;">姓名</label>
          <input v-model="registerForm.name" type="text" placeholder="請輸入姓名" class="input-dark" :class="{ error: errors.name }" />
          <p v-if="errors.name" style="color:#C0504D;font-size:0.75rem;margin-top:0.25rem;">{{ errors.name }}</p>
        </div>
        <div>
          <label style="display:block;font-size:0.7rem;letter-spacing:0.1em;color:#7A9088;margin-bottom:0.4rem;">電子信箱</label>
          <input v-model="registerForm.email" type="email" placeholder="example@email.com" class="input-dark" :class="{ error: errors.email }" />
          <p v-if="errors.email" style="color:#C0504D;font-size:0.75rem;margin-top:0.25rem;">{{ errors.email }}</p>
        </div>
        <div>
          <label style="display:block;font-size:0.7rem;letter-spacing:0.1em;color:#7A9088;margin-bottom:0.4rem;">密碼</label>
          <input v-model="registerForm.password" type="password" placeholder="至少 6 個字元" class="input-dark" :class="{ error: errors.password }" />
          <p v-if="errors.password" style="color:#C0504D;font-size:0.75rem;margin-top:0.25rem;">{{ errors.password }}</p>
        </div>
        <button type="submit" :disabled="submitting" class="btn-gold" style="width:100%;margin-top:0.25rem;">
          {{ submitting ? '註冊中...' : '立即加入' }}
        </button>
        <p style="text-align:center;font-size:0.8rem;color:#7A9088;">
          已有帳號？
          <a href="#" @click.prevent="activeTab='login';errors={}" style="color:#C9A96E;">登入</a>
        </p>
      </form>
    </div>
  </div>
</div>
