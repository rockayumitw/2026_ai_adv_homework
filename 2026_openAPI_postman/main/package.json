{
  "name": "todo-restful-api",
  "version": "1.0.0",
  "private": true,
  "description": "教學用：Node.js + Express + EJS + Tailwind 的 Todo List RESTful API（JWT 認證、記憶體資料）",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "concurrently -n server,css -c blue,magenta \"npm:dev:server\" \"npm:dev:css\"",
    "dev:server": "nodemon src/server.js",
    "dev:css": "tailwindcss -i ./src/styles/input.css -o ./public/css/output.css --watch",
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./public/css/output.css --minify"
  },
  "keywords": [
    "todo",
    "restful",
    "express",
    "ejs",
    "jwt",
    "tailwind"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4.3.0"
  }
}
